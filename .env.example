# Runtime
ENVIRONMENT=local
LOG_LEVEL=INFO

# Host-run service ports. Leave unset locally to use deterministic worktree ports.
API_HOST=127.0.0.1
# API_PORT=9710
WEB_HOST=127.0.0.1
# WEB_PORT=9720

# Integration endpoints and secrets
HERMES_WEBHOOK_SECRET=
HERMES_API_BASE_URL=
HERMES_BRIDGE_URL=http://127.0.0.1:8642
HERMES_BRIDGE_PASSWORD=
HERMES_BRIDGE_SESSION_KEY=personal-dashboard
PERSONAL_DASHBOARD_API_TOKEN=
OPENCLAW_API_BASE_URL=
OPENCLAW_API_TOKEN=

# Future data sources
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_BASE_URL=
PLAID_CLIENT_NAME=Personal Dashboard
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_LANGUAGE=en
PLAID_DAYS_REQUESTED=730
PLAID_WEBHOOK_URL=
PLAID_SYNC_ENABLED=false
DATABASE_URL=
DASHBOARD_DATA_FILE=
CODING_AGENT_STATE_STORE=json
CODING_AGENT_POSTGRES_POOL_SIZE=5
CODING_AGENT_RUN_EVIDENCE_DIR=
CODING_AGENT_RUN_EVIDENCE_RETENTION_DAYS=30
ASIA_TRAVEL_DEALS_API_BASE_URL=
ASIA_TRAVEL_DEALS_API_TOKEN=
ASIA_TRAVEL_DEALS_POLL_INTERVAL_SECONDS=300
HOTEL_RATE_FINDER_API_BASE_URL=http://127.0.0.1:8720
HOTEL_RATE_SYNC_ENABLED=false
HOTEL_RATE_DROP_THRESHOLD=25
HOTEL_RATE_FORCE_REFRESH=false
HOTEL_RATE_JOB_POLL_INTERVAL_MS=1500
HOTEL_RATE_JOB_POLL_ATTEMPTS=20
FLIGHT_SEARCHER_API_BASE_URL=
HOTEL_RATE_FINDER_EVENTS_FILE=
FLIGHTS_EXTENSION_EVENTS_FILE=
PLAID_EVENTS_FILE=
GMAIL_INTAKE_EVENTS_FILE=
CODING_AGENT_PR_POLL_ENABLED=false
CODING_AGENT_PR_PICKUP_ENABLED=false
CODING_AGENT_VALIDATION_ENABLED=false
CODING_AGENT_MAX_REPAIR_ATTEMPTS=3
CODING_AGENT_VALIDATION_TIMEOUT_MS=120000
CODING_AGENT_REVIEW_ENABLED=false
CODING_AGENT_REVIEW_TIMEOUT_MS=120000
# Direct OpenAI-compatible gateway used only by the reviewer worker. Keep this
# credential server-side; it must not reach Hermes task worktrees or the web UI.
CODING_AGENT_REVIEW_GATEWAY_URL=http://127.0.0.1:4000/v1
CODING_AGENT_REVIEW_GATEWAY_KEY=
# Defaults to the persisted task modelPolicy.reviewer.model when unset.
CODING_AGENT_REVIEW_MODEL=
CODING_AGENT_GITHUB_OWNER=michaelmwu
CODING_AGENT_ALLOWED_REPOS=personal-dashboard,moo-infra
CODING_AGENT_PICKUP_REPOS=
CODING_AGENT_BRANCH_PREFIX=hermes
CODING_AGENT_DEFAULT_BASE_BRANCH=origin/main
CODING_AGENT_PORT_BASE=12000
CODING_AGENT_PORT_SLOTS=400
CODING_AGENT_RECONCILE_ENABLED=false
CODING_AGENT_RECONCILE_WATCHDOG_ENABLED=true
CODING_AGENT_STALE_RUNNING_MINUTES=90
CODING_AGENT_RUN_QUIET_MINUTES=10

# Web
WEB_API_BASE_URL=http://127.0.0.1:9710
