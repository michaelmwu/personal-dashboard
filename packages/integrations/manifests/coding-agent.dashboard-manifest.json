{
  "id": "coding-agent",
  "name": "Coding Agent",
  "version": "dashboard-app.v1",
  "baseUrl": "internal:hermes-bridge",
  "panels": [
    {
      "id": "task-queue",
      "type": "task-queue",
      "title": "Coding Tasks",
      "dataSource": "/api/apps/coding-agent/items?type=coding-task",
      "defaultPosition": "operations"
    },
    {
      "id": "active-runs",
      "type": "run-status",
      "title": "Coding Agent Runs",
      "dataSource": "/api/apps/coding-agent/items?type=coding-run",
      "defaultPosition": "operations"
    }
  ],
  "capabilities": [
    {
      "id": "start-coding-task",
      "title": "Start coding task",
      "kind": "agentic",
      "target": "coding-agent",
      "description": "Ask Hermes to create an isolated worktree, execute a coding task, and open a PR.",
      "inputSchema": {
        "repo": "string",
        "title": "string",
        "prompt": "string",
        "mission": "object",
        "baseBranch": "string?",
        "conductorPort": "number?",
        "portRange": "object?",
        "approvalRequired": "boolean?"
      }
    },
    {
      "id": "update-coding-task",
      "title": "Update coding task",
      "kind": "agentic",
      "target": "coding-agent",
      "description": "Resume a registered coding task in its worktree after PR feedback, CI failures, or dashboard follow-up.",
      "inputSchema": {
        "taskId": "string",
        "repo": "string",
        "prNumber": "number?",
        "worktreeDir": "string?",
        "conductorPort": "number?",
        "portRange": "object?",
        "events": "array?"
      }
    },
    {
      "id": "register-coding-task",
      "title": "Register coding task",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/tasks",
      "description": "Persist the task, worktree, Hermes session, PR, and preview URL anchors for one coding task.",
      "inputSchema": {
        "id": "string?",
        "repo": "string",
        "title": "string",
        "branch": "string?",
        "mission": "object?",
        "worktreeDir": "string?",
        "conductorPort": "number?",
        "portRange": "object?",
        "hermesSessionKey": "string?",
        "prNumber": "number?",
        "previewUrl": "string?"
      }
    },
    {
      "id": "plan-coding-task",
      "title": "Plan coding task",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/intake-plan",
      "description": "Turn a coding request into a durable intake plan with clarification questions and risk classification before execution.",
      "inputSchema": {
        "repo": "string?",
        "title": "string?",
        "request": "string",
        "files": "array?",
        "approvedBy": "string?",
        "approvalId": "string?"
      }
    },
    {
      "id": "plan-coding-queue",
      "title": "Plan coding queue",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/queue-plan",
      "description": "Plan task priority, duplicate candidates, and one-task-one-worktree allocation before execution.",
      "inputSchema": {
        "repo": "string?",
        "title": "string?",
        "request": "string",
        "priority": "string?",
        "branch": "string?",
        "prNumber": "number?"
      }
    },
    {
      "id": "pickup-existing-pr",
      "title": "Pick up existing PR",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/pr-pickup",
      "description": "Register an existing pull request as a managed coding-agent task from the dashboard or an explicit pickup comment.",
      "inputSchema": {
        "repo": "string?",
        "githubRepo": "string?",
        "prNumber": "number",
        "title": "string?",
        "branch": "string?",
        "prUrl": "string?",
        "pickupSource": "string?"
      }
    },
    {
      "id": "triage-github-issue",
      "title": "Triage GitHub issue",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/issue-triage",
      "description": "Classify a GitHub issue as trusted work intake or approval-required untrusted text before creating coding tasks.",
      "inputSchema": {
        "repo": "string?",
        "githubRepo": "string?",
        "issueNumber": "number",
        "title": "string",
        "body": "string?",
        "author": "string?",
        "authorAssociation": "string?"
      }
    },
    {
      "id": "sync-pr-status",
      "title": "Sync PR status",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/pr-status",
      "description": "Update a registered coding task from PR checks, review state, comments, or preview deployment data.",
      "inputSchema": {
        "taskId": "string?",
        "repo": "string?",
        "prNumber": "number?",
        "status": "string?",
        "previewUrl": "string?",
        "checks": "object?"
      }
    },
    {
      "id": "validate-coding-task",
      "title": "Validate coding task",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/validate",
      "description": "Persist deterministic validation command results for a coding task before it can move from running to PR-ready.",
      "inputSchema": {
        "taskId": "string",
        "status": "string",
        "commands": "array",
        "maxRepairAttempts": "number?"
      }
    },
    {
      "id": "review-coding-task",
      "title": "Review coding task",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/review",
      "description": "Persist the mission-aware structured review verdict and findings required before a task can become PR-ready.",
      "inputSchema": {
        "taskId": "string",
        "status": "clean|findings|blocked|failed",
        "findings": "array?",
        "definitionOfDone": "array?",
        "model": "object?",
        "riskTier": "string?",
        "maxRepairAttempts": "number?"
      }
    },
    {
      "id": "enqueue-coding-task-item",
      "title": "Enqueue coding task item",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/queue",
      "description": "Append one or more typed work items to a registered coding task queue.",
      "inputSchema": {
        "taskId": "string",
        "items": "array?"
      }
    },
    {
      "id": "reconcile-coding-tasks",
      "title": "Reconcile coding tasks",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/reconcile",
      "description": "Mark orphaned or stale running coding tasks as requiring operator attention during startup reconciliation.",
      "inputSchema": {
        "id": "string?",
        "auditId": "string?",
        "staleRunningMinutes": "number?"
      }
    },
    {
      "id": "run-pr-maintenance",
      "title": "Run PR maintenance",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/pr-maintenance",
      "description": "Plan PR maintenance work after enforcing repo allowlists, branch policy, PR-only rules, and approval requirements.",
      "inputSchema": {
        "taskId": "string?",
        "repo": "string?",
        "prNumber": "number?",
        "actions": "array?",
        "approvedBy": "string?",
        "approvalId": "string?"
      }
    },
    {
      "id": "review-coding-risk",
      "title": "Review coding risk",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/risk-review",
      "description": "Classify coding-agent blast radius and gate high-risk side effects before provider mutation.",
      "inputSchema": {
        "taskId": "string?",
        "repo": "string?",
        "action": "string",
        "files": "array?",
        "approvedBy": "string?",
        "approvalId": "string?",
        "riskAcceptedBy": "string?",
        "riskApprovalId": "string?"
      }
    },
    {
      "id": "record-improvement-signal",
      "title": "Record improvement signal",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/signals",
      "description": "Persist a typed signal from CI, PR reviews, Telegram corrections, guardrails, or Hermes runs for future improvement loops.",
      "inputSchema": {
        "source": "string",
        "kind": "string",
        "severity": "string?",
        "taskId": "string?",
        "repo": "string?",
        "prNumber": "number?",
        "summary": "string",
        "evidence": "array?"
      }
    },
    {
      "id": "record-improvement-finding",
      "title": "Record improvement finding",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/findings",
      "description": "Persist or synthesize recurring coding-agent improvement findings from typed signals.",
      "inputSchema": {
        "title": "string?",
        "summary": "string?",
        "evidence": "array?",
        "proposedActions": "array?",
        "synthesize": "boolean?"
      }
    },
    {
      "id": "record-regression-memory",
      "title": "Record regression memory",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/regression-memory",
      "description": "Persist concise prior failure and root-cause memory so executor runs can avoid repeated bad fixes.",
      "inputSchema": {
        "repo": "string?",
        "checkName": "string?",
        "failureSignature": "string?",
        "rootCause": "string",
        "avoid": "array?",
        "recommendedFix": "string?",
        "evidence": "array?"
      }
    },
    {
      "id": "plan-goal-mutation",
      "title": "Plan goal mutation",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/goal-mutations",
      "description": "Draft GitHub issue, Hermes memory, Telegram, or coding-task mutations from validated findings without provider side effects.",
      "inputSchema": {
        "id": "string?",
        "mutationId": "string?",
        "findingId": "string?",
        "sourceFindingId": "string?",
        "action": "string?",
        "propose": "boolean?",
        "dryRun": "boolean?",
        "approvedBy": "string?",
        "approvalId": "string?"
      }
    },
    {
      "id": "sync-coding-coordination",
      "title": "Sync coding coordination",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/coordination",
      "description": "Attach or update Telegram, dashboard, or GitHub coordination anchors for a managed task.",
      "inputSchema": {
        "taskId": "string",
        "surface": "string",
        "threadId": "string?",
        "chatId": "string?",
        "messageId": "string?",
        "url": "string?"
      }
    },
    {
      "id": "control-coding-task",
      "title": "Control coding task",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/control",
      "description": "Apply typed operator controls such as pause, continue, tests, preview, open-pr, archive, or handoff.",
      "inputSchema": {
        "taskId": "string",
        "action": "pause|continue|approve-mission|handoff|archive|...",
        "requestedBy": "string?",
        "approvedBy": "string?",
        "approvalId": "string?",
        "reason": "string?",
        "blocker": "string?",
        "nextAction": "string?"
      }
    },
    {
      "id": "summarize-coding-handoff",
      "title": "Summarize coding handoff",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/handoff-summary",
      "description": "Persist a concise operator handoff summary from blocked queue items, failed checks, PR events, and task artifacts.",
      "inputSchema": {
        "taskId": "string",
        "summaryId": "string?",
        "blocker": "string?",
        "nextAction": "string?"
      }
    },
    {
      "id": "archive-coding-task",
      "title": "Archive coding task",
      "kind": "deterministic",
      "target": "coding-agent",
      "endpoint": "/api/apps/coding-agent/archive",
      "description": "Archive a completed or abandoned coding task and its remaining queue items.",
      "inputSchema": {
        "taskId": "string",
        "reason": "string?"
      }
    }
  ],
  "eventTypes": [
    "coding-task",
    "coding-run",
    "pr-status",
    "coding-pr-pickup-attempt",
    "coding-issue-triage",
    "coding-reconciliation",
    "coding-handoff-summary",
    "coding-risk-review",
    "coding-improvement-signal",
    "coding-improvement-finding",
    "coding-regression-memory",
    "coding-goal-mutation"
  ]
}
